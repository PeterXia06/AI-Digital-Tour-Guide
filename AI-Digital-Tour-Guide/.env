# 数据库连接（本地留空默认 SQLite，Render 自动注入 MySQL）
DATABASE_URL=mysql+pymysql://root:123456@localhost:3306/lingshan

# DeepSeek API 密钥（必填）
DEEPSEEK_API_KEY=sk-xxxxxxxx

# DeepSeek API 地址（可选，默认官方）
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# 管理后台登录 Token（建议修改）
ADMIN_SECRET_KEY=lingshan-admin-2026

# Azure TTS（可选，不配则用浏览器 TTS）
AZURE_TTS_KEY=
AZURE_TTS_REGION=eastasia
